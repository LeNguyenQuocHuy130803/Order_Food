    {
      "name": "6. VIEW CURRENT CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== CURRENT CART ==========');",
              "    console.log('Cart ID:', jsonData.id);",
              "    console.log('User ID:', jsonData.userId);",
              "    console.log('Total Price:', jsonData.totalPrice);",
              "    console.log('Total Items:', jsonData.items.length);",
              "    console.log('\\n--- Items Detail ---');",
              "    jsonData.items.forEach((item, index) => {",
              "        console.log(`${index + 1}. ${item.productName}`);",
              "        console.log(`   Type: ${item.productType}, ID: ${item.productId}`);",
              "        console.log(`   Price: ${item.priceAtTime}, Qty: ${item.quantity}`);",
              "        console.log(`   Subtotal: ${item.priceAtTime * item.quantity}`);",
              "    });",
              "    console.log('==================================');",
              "} else {",
              "    console.log('✗ View cart failed:', pm.response.text());",
              "}"
            ]
          }
        }
