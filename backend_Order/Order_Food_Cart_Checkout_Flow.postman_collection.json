{
  "info": {
    "_postman_id": "cart-checkout-flow-collection",
    "name": "Order Food - Cart & Checkout Flow",
    "description": "Complete flow: Login -> Add to Cart -> Update Cart -> Checkout -> PayPal Payment -> Order Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. LOGIN & GET TOKEN",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('token', jsonData.data.token);",
              "    pm.environment.set('userId', jsonData.data.user.id);",
              "    console.log('✓ Token saved:', jsonData.data.token.substring(0, 20) + '...');",
              "    console.log('✓ User ID saved:', jsonData.data.user.id);",
              "} else {",
              "    console.log('✗ Login failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. GET OR CREATE CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('cartId', jsonData.id);",
              "    console.log('✓ Cart ID:', jsonData.id);",
              "    console.log('✓ Total Price:', jsonData.totalPrice);",
              "    console.log('✓ Items in cart:', jsonData.items.length);",
              "} else {",
              "    console.log('✗ Get cart failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/carts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts"]
        }
      },
      "response": []
    },
    {
      "name": "2.5. CHECK PRODUCT STOCK (Requires Auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== STOCK CHECK ==========');",
              "    console.log('All available:', jsonData.allAvailable);",
              "    console.log('Insufficient items:', jsonData.insufficientItems);",
              "    jsonData.items.forEach(function(item) {",
              "        console.log('---');",
              "        console.log('Product:', item.productName);",
              "        console.log('Status:', item.status);",
              "        console.log('Requested:', item.requestedQuantity, '| Available:', item.availableQuantity);",
              "        console.log('Message:', item.message);",
              "    });",
              "    console.log('=================================');",
              "} else {",
              "    console.log('✗ Stock check failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"productType\": \"FOOD\",\n      \"productId\": 1,\n      \"requestedQuantity\": 2\n    },\n    {\n      \"productType\": \"DRINK\",\n      \"productId\": 1,\n      \"requestedQuantity\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/stocks/check",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stocks", "check"]
        }
      },
      "response": []
    },
    {
      "name": "3. ADD FOOD TO CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('cartItemId1', jsonData.items[jsonData.items.length - 1].id);",
              "    console.log('✓ Food added to cart');",
              "    console.log('✓ New Total Price:', jsonData.totalPrice);",
              "    console.log('✓ Total Items in cart:', jsonData.items.length);",
              "    var lastItem = jsonData.items[jsonData.items.length - 1];",
              "    console.log('✓ Last item:', lastItem.productName, '| Qty:', lastItem.quantity, '| Price:', lastItem.priceAtTime);",
              "} else {",
              "    console.log('✗ Add to cart failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productType\": \"FOOD\",\n  \"productId\": 1,\n  \"quantity\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/carts/items",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts", "items"]
        }
      },
      "response": []
    },
    {
      "name": "4. ADD DRINK TO CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('cartItemId2', jsonData.items[jsonData.items.length - 1].id);",
              "    console.log('✓ Drink added to cart');",
              "    console.log('✓ New Total Price:', jsonData.totalPrice);",
              "    console.log('✓ Total Items in cart:', jsonData.items.length);",
              "} else {",
              "    console.log('✗ Add drink failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productType\": \"DRINK\",\n  \"productId\": 1,\n  \"quantity\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/carts/items",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts", "items"]
        }
      },
      "response": []
    },
    {
      "name": "5. ADD FRESH PRODUCT TO CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('✓ Fresh product added to cart');",
              "    console.log('✓ Total Items in cart:', jsonData.items.length);",
              "    console.log('✓ Cart Total Price:', jsonData.totalPrice);",
              "} else {",
              "    console.log('✗ Add fresh product failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productType\": \"FRESH\",\n  \"productId\": 1,\n  \"quantity\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/carts/items",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts", "items"]
        }
      },
      "response": []
    },
    {
      "name": "6. VIEW CURRENT CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== CURRENT CART ==========');",
              "    console.log('Cart ID:', jsonData.id);",
              "    console.log('Total Price:', jsonData.totalPrice);",
              "    console.log('Total Items:', jsonData.items.length);",
              "    jsonData.items.forEach(function(item, index) {",
              "        console.log((index+1) + '. ' + item.productName + ' (' + item.productType + ')');",
              "        console.log('   Qty:', item.quantity, '| Price:', item.priceAtTime);",
              "    });",
              "    console.log('==================================');",
              "} else {",
              "    console.log('✗ View cart failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/carts",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts"]
        }
      },
      "response": []
    },
    {
      "name": "7. UPDATE CART ITEM QUANTITY",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('✓ Cart item quantity updated');",
              "    console.log('✓ New Total Price:', jsonData.totalPrice);",
              "} else {",
              "    console.log('✗ Update cart item failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/carts/items/{{cartItemId1}}?quantity=3",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts", "items", "{{cartItemId1}}"],
          "query": [{ "key": "quantity", "value": "3" }]
        }
      },
      "response": []
    },
    {
      "name": "8. REMOVE ITEM FROM CART",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('✓ Item removed from cart');",
              "    console.log('✓ Remaining items:', jsonData.items.length);",
              "    console.log('✓ New Total Price:', jsonData.totalPrice);",
              "} else {",
              "    console.log('✗ Remove item failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/carts/items/{{cartItemId2}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "carts", "items", "{{cartItemId2}}"]
        }
      },
      "response": []
    },
    {
      "name": "9. GET USER ADDRESSES",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.addresses && jsonData.addresses.length > 0) {",
              "        var defaultAddr = jsonData.addresses.find(function(a) { return a.isDefault === true; });",
              "        if (defaultAddr) {",
              "            pm.environment.set('addressType', defaultAddr.type);",
              "            console.log('✓ Default address type:', defaultAddr.type);",
              "        } else {",
              "            pm.environment.set('addressType', jsonData.addresses[0].type);",
              "            console.log('✓ Using first address type:', jsonData.addresses[0].type);",
              "        }",
              "        console.log('✓ Total saved addresses:', jsonData.addresses.length);",
              "    } else {",
              "        pm.environment.set('addressType', '');",
              "        console.log('⚠ No saved addresses — will use inline address in checkout');",
              "    }",
              "} else {",
              "    console.log('✗ Get addresses failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "users", "{{userId}}"]
        }
      },
      "response": []
    },
    {
      "name": "10. CHECKOUT - CREATE ORDER (PENDING)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('orderId', jsonData.id);",
              "    console.log('========== ORDER CREATED ==========');",
              "    console.log('✓ Order ID:', jsonData.id);",
              "    console.log('✓ Status:', jsonData.status, '(PENDING - chờ thanh toán)');",
              "    console.log('✓ Total Price (VND):', jsonData.totalPrice);",
              "    console.log('✓ Delivery Address:', jsonData.address);",
              "    console.log('✓ Notes:', jsonData.notes);",
              "    console.log('✓ Items:', jsonData.items.length);",
              "    jsonData.items.forEach(function(item, i) {",
              "        console.log('  ' + (i+1) + '. ' + item.productName + ' x' + item.quantity + ' @ ' + item.priceAtTime);",
              "    });",
              "    console.log('');",
              "    console.log('⏩ Next: Run #11 to create PayPal payment');",
              "    console.log('===================================');",
              "} else {",
              "    console.log('✗ Checkout failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"addressType\": \"HOME\",\n  \"notes\": \"Giao nhanh vào sáng sớm nhé!\"\n}",
          "options": {
            "raw": { "language": "json" }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders/checkout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "orders", "checkout"]
        }
      },
      "response": []
    },
    {
      "name": "11. CREATE PAYPAL PAYMENT (Get approveUrl)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('paypalOrderId', jsonData.paypalOrderId);",
              "    console.log('========== PAYPAL ORDER CREATED ==========');",
              "    console.log('✓ PayPal Order ID:', jsonData.paypalOrderId);",
              "    console.log('✓ Our Order ID:', jsonData.orderId);",
              "    console.log('✓ Amount VND:', jsonData.amountVND);",
              "    console.log('✓ Amount USD:', jsonData.amountUSD);",
              "    console.log('');",
              "    console.log('🔗 PAYPAL APPROVAL URL (mở link này trong browser):');",
              "    console.log(jsonData.approveUrl);",
              "    console.log('');",
              "    console.log('📋 HƯỚNG DẪN:');",
              "    console.log('  1. Copy link trên, mở trong browser');",
              "    console.log('  2. Login PayPal Sandbox');",
              "    console.log('  3. Bấm Approve/Pay');",
              "    console.log('  4. Browser sẽ redirect về: http://localhost:3000/payment/success?token=...');",
              "    console.log('  5. Copy phần ?token=XXX (đó là paypalOrderId)');",
              "    console.log('  6. Set vào biến paypalOrderId rồi chạy #13');",
              "    console.log('==========================================');",
              "} else {",
              "    console.log('✗ Create PayPal payment failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": {{orderId}}\n}",
          "options": {
            "raw": { "language": "json" }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/payments/paypal/create-payment",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payments", "paypal", "create-payment"]
        }
      },
      "response": []
    },
    {
      "name": "12. [MANUAL STEP] APPROVE ON PAYPAL SANDBOX",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log('========== HƯỚNG DẪN APPROVE TRÊN PAYPAL SANDBOX ==========');",
              "console.log('');",
              "console.log('⚠️  ĐÂY LÀ BƯỚC THỦ CÔNG - KHÔNG GỌI API');",
              "console.log('');",
              "console.log('BƯỚC 1: Lấy approveUrl từ kết quả request #11');",
              "console.log('BƯỚC 2: Mở link đó trong browser');",
              "console.log('BƯỚC 3: Đăng nhập PayPal Sandbox bằng tài khoản buyer:');",
              "console.log('   Email   : sb-xxxxx@personal.example.com');",
              "console.log('   Password: Seller@123 (hoặc pass sandbox của bạn)');",
              "console.log('BƯỚC 4: Bấm nút \"Pay Now\" / \"Approve\"');",
              "console.log('BƯỚC 5: Browser redirect về:');",
              "console.log('   http://localhost:3000/payment/success?token=PAYPAL_ORDER_ID&PayerID=...');",
              "console.log('BƯỚC 6: Lấy giá trị ?token=... đó chính là paypalOrderId');",
              "console.log('   (Hoặc dùng paypalOrderId đã lưu từ bước #11)');",
              "console.log('BƯỚC 7: Chạy request #13 để capture payment');",
              "console.log('');",
              "console.log('💡 paypalOrderId hiện tại:', pm.environment.get(\"paypalOrderId\"));",
              "console.log('==========================================================');"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "about:blank",
          "raw": "about:blank"
        }
      },
      "response": []
    },
    {
      "name": "13. CAPTURE PAYPAL PAYMENT (Confirm & Mark Order PAID)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== PAYMENT CAPTURE RESULT ==========');",
              "    console.log('✓ Success:', jsonData.success);",
              "    console.log('✓ PayPal Status:', jsonData.paypalStatus);",
              "    console.log('✓ Order ID:', jsonData.orderId);",
              "    console.log('');",
              "    if (jsonData.paypalStatus === 'COMPLETED' && jsonData.success === true) {",
              "        console.log('✅ THANH TOÁN THÀNH CÔNG!');",
              "        console.log('✅ Order tự động cập nhật: PENDING → PAID');",
              "        console.log('✅ Kho hàng đã được trừ');",
              "        console.log('');",
              "        console.log('⏩ Next: Chạy #14 để xem lịch sử thanh toán');",
              "        console.log('⏩ Hoặc chạy #16 để xem chi tiết order');",
              "    } else {",
              "        console.log('❌ THANH TOÁN THẤT BẠI - Status: ' + jsonData.paypalStatus);",
              "        console.log('❌ Order tự động HỦY và hoàn kho');",
              "    }",
              "    console.log('============================================');",
              "} else {",
              "    console.log('✗ Capture failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payments/paypal/confirm?paypalOrderId={{paypalOrderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payments", "paypal", "confirm"],
          "query": [{ "key": "paypalOrderId", "value": "{{paypalOrderId}}" }]
        }
      },
      "response": []
    },
    {
      "name": "14. GET PAYMENT HISTORY",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== PAYMENT HISTORY ==========');",
              "    console.log('Total transactions:', jsonData.length);",
              "    jsonData.forEach(function(txn, i) {",
              "        console.log('--- Transaction ' + (i+1) + ' ---');",
              "        console.log('  TxnRef (PayPal ID):', txn.txnRef);",
              "        console.log('  Amount:', txn.amountFormatted);",
              "        console.log('  Status:', txn.status, '(' + txn.statusVN + ')');",
              "        console.log('  Provider:', txn.provider);",
              "        console.log('  Order Info:', txn.orderInfo);",
              "        console.log('  PayPal Order ID:', txn.paypalOrderId);",
              "        console.log('  Capture ID:', txn.captureId);",
              "        console.log('  Created At:', txn.createdAt);",
              "    });",
              "    console.log('=====================================');",
              "} else {",
              "    console.log('✗ Get payment history failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payments/history",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payments", "history"]
        }
      },
      "response": []
    },
    {
      "name": "15. CONFIRM ORDER (PAID → CONFIRMED)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('========== ORDER CONFIRMED ==========');",
              "    console.log('✓ Order ID:', jsonData.id);",
              "    console.log('✓ Status:', jsonData.status);",
              "    if (jsonData.status === 'CONFIRMED') {",
              "        console.log('✅ Order đã CONFIRMED - hệ thống sẽ tự chuẩn bị');",
              "    }",
              "    console.log('======================================');",
              "} else {",
              "    console.log('✗ Confirm order failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
