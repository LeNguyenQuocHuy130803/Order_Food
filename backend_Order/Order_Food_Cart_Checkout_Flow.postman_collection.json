    {
      "name": "9. GET USER ADDRESSES",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.addresses && jsonData.addresses.length > 0) {",
              "        var defaultAddr = jsonData.addresses.find(a => a.isDefault === true);",
              "        if (defaultAddr) {",
              "            pm.environment.set('addressType', defaultAddr.type);",
              "            console.log('✓ Found default address type:', defaultAddr.type);",
              "        } else {",
              "            pm.environment.set('addressType', jsonData.addresses[0].type);",
              "            console.log('✓ Using first address type:', jsonData.addresses[0].type);",
              "        }",
              "        console.log('✓ Total saved addresses:', jsonData.addresses.length);",
              "    } else {",
              "        console.log('⚠ No saved addresses found - will need to provide address in checkout');",
              "    }",
              "} else {",
              "    console.log('✗ Get addresses failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
