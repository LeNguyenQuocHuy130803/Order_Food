              "    console.log('✓ Number of items:', jsonData.items.length);",
              "    console.log('\\n--- Order Items ---');",
              "    jsonData.items.forEach((item, index) => {",
              "        console.log(`${index + 1}. ${item.productName}`);",
              "        console.log(`   Qty: ${item.quantity}, Price: ${item.priceAtTime}`);",
              "    });",
              "    console.log('====================================');",
              "} else {",
              "    console.log('✗ Checkout failed:', pm.response.text());",
