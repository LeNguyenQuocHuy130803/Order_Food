    {
      "name": "7. UPDATE CART ITEM QUANTITY",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    console.log('✓ Cart item quantity updated');",
              "    console.log('✓ New Total Price:', jsonData.totalPrice);",
              "    var updatedItem = jsonData.items.find(item => item.productType === 'FOOD');",
              "    console.log('✓ Updated FOOD item quantity:', updatedItem.quantity);",
              "} else {",
              "    console.log('✗ Update cart item failed:', pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/carts/items/{{cartItemId1}}?quantity=3",
          "host": [
            "{{baseUrl}}"
